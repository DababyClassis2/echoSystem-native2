<?xml version="1.0" encoding="utf-8"?>
<!--
    LocalShare is a LAN-only app. No internet connections are made.
    Cleartext HTTP is required for connections to LAN IP addresses.
    Self-signed TLS certs generated by the app are trusted via user store.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
</network-security-config>